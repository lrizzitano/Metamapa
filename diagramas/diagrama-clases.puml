@startuml MetaMapa

class Usuario {
    (nombre)
    (apellido)
    (edad)
    esContribuyente: bool
    --
    verHechosFiltrados(coleccion, filtro)
    crearSolicitud(hecho,fundamentacion)
    verHechos(Coleccion)
}

class Administrador {
--
    crearColeccion(titulo,descripcion,criterio,fuente)
    verSolicitudes()
    crearFuenteEstatica(pathArchivo)
    aceptarSolicitud(solicitud)
    rechazarSolicitud(solicitud)

}

together {
    class Solicitud {
        hecho
        fundamentacion
        solicitudes
        responsable
        --
        aceptar(admin)
        rechhazar(admin)

    }

    class Coleccion {
        titulo
        descripcion
        criterioDePertenencia
        fuente
        --
        hechos(filtro)
    }

    interface Fuente {
        --
        obetenerHechos(filtro)
    }

    class Hecho {
        titulo
        descripcion
        categoria
        latitud
        longitud
        fechaAcontecimiento
        fechaCarga
        origen
        --
    }

    enum Origen {
        MANUAL
        DATASET
        CONTRIBUYENTE
    }
}



class FuenteEstatica {
    pathArchivo
    --
    crearHechoDesdeFila()
    estaRepetido(unHecho, hechos)
}



enum Filtro {
  TITULO
  DESCRIPCION
  CATEGORIA
  LATITUD_MAYOR
  LATITUD_MENOR
  LONGITUD_MAYOR
  LONGITUD_MENOR
  FECHA_CARGA_ANTES
  FECHA_CARGA_DESPUES
  FECHA_HECHO_ANTES
  FECHA_HECHO_DESPUES
  --
  crearFiltro(valor)
}

Administrador -r-|> Usuario

Administrador ..> Coleccion
Administrador ..> FuenteEstatica
Administrador ..>Solicitud

Usuario ..> Coleccion
Usuario ..>Filtro


Coleccion --> Fuente
Coleccion .r.> Filtro

Fuente -l-> "*" Hecho
Fuente .r.>Filtro

FuenteEstatica .u.|> Fuente


Hecho -l-> Origen

Solicitud --> Hecho
Solicitud -u-> Administrador

Solicitud -[hidden] Coleccion

@enduml