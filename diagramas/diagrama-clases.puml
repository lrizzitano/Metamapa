@startuml MetaMapa

class Usuario {
    +(nombre)
    +(apellido)
    +(edad)
    +esContribuyente
    +tipoNavegacion
    --
    +contribuir()
}

class Administrador {
    +nombre
    +apellido
    +edad
}

class SolicitudDeEliminacion {
    +hecho
    +fundamentacion
    +responsable
    -solicitudesDeEliminacionRepo
    --
    +aceptar(admin)
    +rechhazar(admin)
}

interface SolicitudDeEliminacionRepo {
    --
    +nuevaSolicitud(solicitud)
    +aceptarSolicitud(solicitud)
    +rechazarSolicitud(solicitud)
    +getPendientes()
    +getAceptadas()
    +getRechazadas()
    +getRechazos(hecho)
    +estaEliminado(hecho)
    +hechosEliminados()
}

interface DetectorDeSpam {
    --
    +esSpam(solicitud)
}


class Coleccion {
    +titulo
    +descripcion
    +id
    -criterioDePertenencia
    -criterioConsenso
    -fuente
    --
    +hechos(filtro)
    -filtrarEliminados()
    -filtrarConsencuados()
}

abstract class CriterioConsenso {
    +fuentesRepository
    +hechosConsensuados
    +algoritmo {abstract}
    -ultimaActualizacion
    -intervaloActualizacion
    --
    +getHechosConsensuados()
}

class Backup {
    +fuenteDinamica
    -ultimaActualizacion
    -intervaloActualizacion
    --
    +backupear()
}

class FuentesRepository {
    fuentes
    --
    getFuentes()
}

interface Fuente {
    --
    +obetenerHechos(filtro)
}

class Hecho {
    +titulo
    +descripcion
    +categoria
    +latitud
    +longitud
    +fechaAcontecimiento
    +fechaCarga
    +origen
    +(usuario)
    +(multimedia)
    --
}

enum Origen {
    MANUAL
    DATASET
    CONTRIBUYENTE
}

interface Filtro {
    +asPredicate()
    +toQueryParam(prefix, delimiter, suffix)
}

class FuenteEstatica {
    -pathArchivo
    --
    -crearHechoDesdeFila()
}

class FuenteDinamica {
    -hechos
    -solicitudes
    --
    +aceptarSolicitudDeCambio(solicitudDeCambio)
    +rechazarSolicitudDeCambio(solicitudDeCambio)
    +agregarHecho(hecho)
    +eliminarHecho(hecho)
}

interface  HechoRepository {
    +obtenerTodos()
    +actualizar(hechoParaCambiar, hechoModificado)
    +agregar(hecho)
    +eliminar(hecho)
}

interface SolicitudDeCambioRepository {
    +crear(solicitudDeCambio)
    +aceptar(solicitudDeCambio)
    +rechazar(solicitudDeCambio)
}

class FuenteDemo {
    -hechos
    -url
    -conexionDemo
    -intervaloActualizacion
    -ultimaActualizacion
    --
    -parseHecho(fila)
}

class FuenteMetaMapa {
    -urlAPI
    --
    +obetenerHechosDeColeccion(coleccion, filtro)
    +enviarSolicitudDeEliminacion(solicitud)
}

class CalendarizablesRepository {
    FuentesCalendarizadas
    --
    getPendientesDeActualizacion()
}

interface Calendarizable {
    tocaActualizar()
    actualizar()
}

class Agregador {
    -fuentes
    -hechos
    -intervaloActualizacion
    -ultimaActualizacion
}

Administrador -r-|> Usuario


Coleccion --> Fuente
Coleccion .r.> Filtro
Coleccion --> CriterioConsenso

CriterioConsenso -[hidden]l- Filtro

Fuente -l-> "*" Hecho
Fuente .r.>Filtro

FuenteEstatica .u.|> Fuente
Calendarizable -u-|> Fuente
FuenteMetaMapa .u.|> Fuente
FuenteDemo .u.|> Calendarizable
FuenteDinamica .u.|> Fuente
FuenteDinamica --> HechoRepository
FuenteDinamica --> SolicitudDeCambioRepository

CriterioConsenso ..|> Calendarizable
CriterioConsenso -u-> FuentesRepository

Agregador .u.|> Calendarizable

CalendarizablesRepository -r->"*" Calendarizable

Hecho -l-> Origen

SolicitudDeEliminacion --> Hecho
SolicitudDeEliminacion -u-> Administrador

SolicitudDeEliminacionRepo *-- SolicitudDeEliminacion
DetectorDeSpam <.. SolicitudDeEliminacionRepo
SolicitudDeEliminacionRepo <-- Coleccion

Backup .u.|> Calendarizable
Backup -u-> FuenteDinamica



@enduml