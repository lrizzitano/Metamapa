@startuml MetaMapa

class Usuario {
    (nombre)
    (apellido)
    (edad)
    esContribuyente: bool
    --
    verHechos(coleccion, filtro)
    contribuir(hecho)
    crearSolicitud()
}

class Administrador {
    crearColeccion()
    verSolicitudes()
    crearFuenteEstatica(pathArchivo)
    aceptarSolicitud(solicitud)
    rechazarSolicitud(solicitud)

}

class Solicitud {
    hecho
    fundamentacion
    estado
    --
    setEstado(estado)
}

class Solicitudes{
    pendientes[]
    aceptadas[]
    rechazadas[]
    --
    hechosEliminados()
}

class Coleccion {
    titulo
    descripcion
    criterioDePertenencia
    fuente
    --
    hechos(filtro)
}

interface Fuente {
    --
    obetenerHechos(criterio)
}

class FuenteEstatica {
    pathArchivo
    --
}

class FuenteDinamica {
    --
    agregarHecho(hecho)
}

class Hecho {
    titulo
    descripcion
    categoria
    ubicacion
    fechaAcontecimiento
    fechaCarga
    origen
    (multimedia)
    (contribuyente)
    --
}

enum Estado {
    PENDIENTE
    ACEPTADA
    RECHAZADA
}

enum Origen {
    MANUAL
    DATASET
    CONTRIBUYENTE
}


Administrador -r-|> Usuario

Administrador ..> Coleccion
Administrador .l.> Solicitudes
Administrador ..> FuenteEstatica

Usuario ..> FuenteDinamica
Usuario ..> Coleccion


Coleccion --> Fuente
Coleccion .l.> Solicitudes

Fuente -l-> "*" Hecho

FuenteEstatica .u.|> Fuente
FuenteDinamica .u.|> Fuente

Hecho -l-> Origen

Solicitud -l-> Estado
Solicitud --> Hecho

Solicitudes -->"*" Solicitud

