@startuml

skinparam componentStyle uml1

left to right direction

node "Agregador" {

    database Colecciones
    database Solicitudes

    interface "Contribuir(hecho)"
    interface "VerHechosFiltrados(coleccion, filtro)"

    [Dominio] -- Colecciones
    [Dominio] -- Solicitudes
    
    "VerHechosFiltrados(coleccion, filtro)" -- [Dominio]
    "Contribuir(hecho)" -- [Dominio]
}

node "FuenteEstatica" {

    interface "ObtenerHechos(criterio)" as InterfazEstaticos

    database Archivo

    InterfazEstaticos -- [Procesador]
    [Procesador]  -- Archivo

    [Dominio] -- InterfazEstaticos
}

 actor "Usuario"
 "Usuario" -- "Contribuir(hecho)"
 "Usuario" -- "VerHechosFiltrados(coleccion, filtro)"


@enduml