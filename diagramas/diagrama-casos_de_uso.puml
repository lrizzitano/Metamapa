@startuml
left to right direction

actor Visualizador
actor Administrador
actor Contribuyente


rectangle {
 usecase "Ver colección" as UC1
 usecase "Evaluar solicitudes" as UC2
 usecase "Crear colección" as UC3
 usecase "Crear fuente" as UC4
 usecase "Crear hecho" as UC5
 usecase "Editar hecho" as UC6

 usecase "Generar solicitud" as UC1.1
 usecase "Registrarse" as UC0.5
}

Visualizador -- UC1
Administrador -- UC2
Administrador -- UC3
Administrador -- UC4
Contribuyente -- UC5
Contribuyente -- UC6



UC1 <.. UC1.1 : <extends>
UC5 <.. UC0.5 : <extends>
UC6 ..> UC0.5: <includes>

@enduml