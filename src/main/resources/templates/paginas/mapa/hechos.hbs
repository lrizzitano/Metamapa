<div class="hechos">
    {{#each hechos}}
        <button class="hecho" type="button" onclick="openModal('detalleHecho')">
            <h1>{{titulo}}</h1>
            <p>{{descripcion}}</p>

            <div class="invisible">
                En ubicacion:
                <p>{{longitud}} : {{latitud}}</p>
            </div>
        </button>
    {{/each}}
</div>

{{> templates/modals/detalleHecho}}