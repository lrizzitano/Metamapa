<div class="hechos">
    {{#each hechos}}
        <button class="card-hecho" type="button"
                data-multimedia="{{multimedia}}"
                data-fechaAcontecimiento="{{fechaAcontecimiento}}"
                data-titulo="{{titulo}}"
                data-descripcion="{{descripcion}}"
                data-categoria="{{categoria}}"
                data-latitud="{{latitud}}"
                data-longitud="{{longitud}}"
                data-fechaCarga="{{fechaCarga}}"
                data-provincia="{{provincia}}"
                data-contribuyente="{{contribuyente.nombre}}"
                onclick="crearModalDetalleHecho(this)">

            <div class="card-hecho-contenido">
                <div class="card-hecho-multimedia-fecha">
                    <div class="card-hecho-contenedor-imagen">
                        <img src={{multimedia}} alt="Imagen del hecho">
                    </div>
                    <p>{{fechaAcontecimiento}}</p>
                </div>

                <div class="card-hecho-titulo-subtitulo">
                    <p id="titulo"><b>{{titulo}}</b></p>
                    <p>{{descripcion}}</p>
                </div>
            </div>

            <div class="card-hecho-categoria">
                <p><b>Categoría: </b></p>
                <p>{{categoria}}</p>
            </div>

            <div class="invisible" id="longitud">
                {{longitud}}
            </div>
            <div class="invisible" id="latitud">
                {{latitud}}
            </div>
        </button>
    {{/each}}
</div>

{{> templates/modals/detalleHecho}}