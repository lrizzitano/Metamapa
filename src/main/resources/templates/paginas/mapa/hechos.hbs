<div class="hechos">
    {{#each hechos}}
        <button class="card-hecho" type="button"
                data-hecho='{{json this}}'
                onclick="crearModalDetalleHecho(this)">

            <div class="card-hecho-contenido">
                <div class="card-hecho-imagen-fecha">
                    <div class="card-hecho-contenedor-imagen">
                        <img src={{imagen}} alt="Imagen del hecho">
                    </div>
                    <p>{{fechaAcontecimiento}}</p>
                </div>

                <div class="card-hecho-titulo-subtitulo">
                    <p class="titulo-card-hecho" id="titulo"><b>{{titulo}}</b></p>
                    <p>{{descripcion}}</p>
                </div>
            </div>

            <div class="card-hecho-categoria">
                <p><b>Categoría: </b></p>
                <p>{{categoria}}</p>
            </div>
        </button>
    {{/each}}
</div>

{{> templates/modals/detalleHecho}}