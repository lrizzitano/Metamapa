{{#partial "seccion"}}
    <div class="colecciones">
    {{#each colecciones}}
        <div class="boton coleccion">
            <div class="contenedor vertical" style="align-items: start">
                <h2><b>{{titulo}}</b></h2>
                <p>Descripcion</p>
                <p><b>Categoria:</b> Locuras locas</p>
                <p><b>Desde:</b> Neuquen</p>
                <p><b>Hasta:</b> Ulises</p>
                <p><b>Fuentes:</b> Neuquen</p>
                <p><b>Consenso:</b> Ulises</p>
                <button class="boton secundario" style="margin-bottom: 0.5rem"
                        onclick="openModal('modificarColeccion')">Editar</button>
            </div>
        </div>
    {{/each}}
    </div>
{{/partial}}

{{> templates/paginas/panelDeControl/panel}}
{{> templates/modals/modificarColeccion}}