<link rel="stylesheet" href="/css/form.css">

{{#partial "seccion"}}
    <section class="contenedor-form">
        <div class="panel">
            <form class="form" style="width: 100%" action="/colecciones" method="POST">

                <label for="titulo">Titulo</label>
                <input id="titulo" name="titulo" type="text" placeholder="Elija un titulo">

                <label for="descripcion">Descripcion</label>
                <input  id="descripcion" name="descripcion" type="text" class="largo" placeholder="Descripción de la colección"/>

                <label>Criterio de Pertenencia</label>
                <div class="contenedor-doble">
                    <div>
                        <label for="categoria">Categoria</label>
                        <input id="categoria" name="categoria" type="text" placeholder="Categoría"/>
                    </div>

                    <div>
                        <label for="fechaAnterior">Desde</label>
                        <input id="fechaAnterior" name="fechaAnterior" style="width: fit-content" type="date" placeholder="Fecha anterior"/>
                    </div>

                    <div>
                        <label for="fechaPosterior">Hasta</label>
                        <input id="fechaPosterior" name="fechaPosterior" style="width: fit-content" type="date" placeholder="Fecha porterior"/>
                    </div>
                </div>

                <label for="fuente">Fuentes</label>
                <select id="fuente" name="fuente" multiple>
                    <option value="metamapa">MetaMapa</option>
                    <option value="dinamica">Dinamica</option>
                    <option value="estatica">Estatica</option>
                </select>

                <label for="consenso">Criterio de Consenso</label>
                <select id="consenso" name="consenso">
                    <option value="sinConsenso" selected>Sin Consenso</option>
                    <option value="absoluto">Absoluto</option>
                    <option value="mayoriaSimple">Mayoría Simple</option>
                    <option value="multiplesMenciones">Multiples Menciones</option>
                </select>

                <button class="boton secundario" type="submit">Subir</button>

            </form>
        </div>
    </section>
{{/partial}}

{{> templates/paginas/panelDeControl/panel}}