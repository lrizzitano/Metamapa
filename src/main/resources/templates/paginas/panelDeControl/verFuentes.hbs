
{{#partial "seccion"}}
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <div class="panel tabla">
        <h2>Tabla de Fuentes</h2>
    </div>
    <table class="tabla fuentes">
        <thead>
            <tr>
                <th>ID</th>
                <th>Fuente</th>
                <th>Detalle</th>
            </tr>
        </thead>
        <tbody>
            {{#each fuentes}}
            <tr>
                <td class="columna centrada id"><p><b>{{id}}</b></p></td>
                <td><p style="font-size: 1.1rem">{{nombre}}</p></td>
                <td><p style="font-size: 1.1rem ">{{detalle}}</p></td>
            </tr>
            {{/each}}
        </tbody>
    </table>
{{/partial}}

{{> templates/paginas/panelDeControl/panel}}
