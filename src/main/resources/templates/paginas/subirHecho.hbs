{{#partial "dependencias"}}
    <link rel="stylesheet" href="/css/form.css">
{{/partial}}

{{#partial "contenido"}}
    <section class="contenedor-form">
        <div class="panel">
            <div class="contenedor-titulo-volver">

                <div class="contenedor-titulo izq">
                    <a class="enlace" href="/">
                        <button class="boton secundario">
                            volver
                        </button>
                    </a>
                </div>

                <h2>Subir nuevo hecho</h2>

                <div class="contenedor-titulo der">
                    <button class="boton-secundario relleno">volver</button>
                </div>
            </div>
            <form class="form" action="/hechos" method="POST">

                <label for="titulo">Titulo</label>
                <input id="titulo" type="text" placeholder="Elija un titulo" name="titulo">

                <label for="categoria">Categoria</label>
                <input id="categoria" type="text" placeholder="Elija una categoria" name="categoria">

                <label for="fecha_hecho">Fecha</label>
                <input id="fecha_hecho" name="fecha_hecho" type="datetime-local">

                <label for="descripcion">Descripcion</label>
                <input id="descripcion" type="text" placeholder="Describa el hecho" name="descripcion">

                <label for="provincia">Provincia:</label>
                <select id="provincia" name="provincia" required>
                    <option value="PROVINCIA_DESCONOCIDA">Provincia desconocida</option>
                    <option value="CABA">CABA</option>
                    <option value="BUENOS_AIRES">Buenos Aires</option>
                    <option value="ENTRE_RIOS">Entre Ríos</option>
                    <option value="SANTA_FE">Santa Fe</option>
                    <option value="CORRIENTES">Corrientes</option>
                    <option value="MISIONES">Misiones</option>
                    <option value="FORMOSA">Formosa</option>
                    <option value="CHACO">Chaco</option>
                    <option value="SANTIAGO_DEL_ESTERO">Santiago del Estero</option>
                    <option value="TUCUMAN">Tucumán</option>
                    <option value="SALTA">Salta</option>
                    <option value="JUJUY">Jujuy</option>
                    <option value="CATAMARCA">Catamarca</option>
                    <option value="LA_RIOJA">La Rioja</option>
                    <option value="SAN_JUAN">San Juan</option>
                    <option value="SAN_LUIS">San Luis</option>
                    <option value="MENDOZA">Mendoza</option>
                    <option value="CORDOBA">Córdoba</option>
                    <option value="LA_PAMPA">La Pampa</option>
                    <option value="NEUQUEN">Neuquén</option>
                    <option value="RIO_NEGRO">Río Negro</option>
                    <option value="CHUBUT">Chubut</option>
                    <option value="SANTA_CRUZ">Santa Cruz</option>
                    <option value="TIERRA_DEL_FUEGO">Tierra del Fuego</option>
                </select>

                <label for="multimedia">Multimedio</label>
                <input id="multimedia" type="text" placeholder="Link a multimedia" name="multimedia"/>

                <div class="contenedor-doble latitud-longitud">
                    <div class="contenedor-latitud">
                        <label for="latitud">Latitud</label>
                        <input id="latitud" type="number" name="latitud"/>
                    </div>

                    <div class="contenedor-longitud">
                        <label for="longitud">Latitud</label>
                        <input id="longitud" type="number" name="longitud"/>
                    </div>
                </div>
                <button class="boton secundario" type="submit">Subir</button>
            </form>
        </div>
    </section>
{{/partial}}

{{> templates/layout}}