{{#if resultadoEstadistico}}
    <div class="datos-extra">
        <h2>Información relevante</h2>
        <div class="extra porcentajeSpam">
            <p><b>La cantidad total de solicitudes rechazadas es: </b> {{rechazosTotal}}</p>
            <p><b>La cantidad total de solicitudes rechazadas por spam: </b> {{rechazosSpam}}</p>
            <p><b>El porcentaje total de solicitudes con spam es: </b> {{porcentaje}}</p>
        </div>
    </div>
    <div class="wrapper-tabla">
        <table class="tabla colecciones">
            <thead>
            <tr>
                <th>Hecho</th>
                <th>N° de rechazos totales</th>
                <th>N° de rechazos por spam</th>
            </tr>
            </thead>
            <tbody>
            {{#each resultadoEstadistico}}
                <tr>
                    <td><p>{{tituloHecho}}</p></td>
                    <td><p>{{cantidadRechazadas}}</p></td>
                    <td><p>{{cantidadSpam}}</p></td>
                </tr>
            {{/each}}
            </tbody>
        </table>
    </div>
{{else}}
    <div class="sin-contenido-estadistico">
        <img src="https://cdn-icons-png.flaticon.com/128/4500/4500139.png">
        <p><b>Realice una busqueda para ver las estadisticas</b></p>
    </div>
{{/if}}