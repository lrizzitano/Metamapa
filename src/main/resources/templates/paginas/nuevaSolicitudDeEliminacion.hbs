{{#partial "dependencias"}}
    <link rel="stylesheet" href="/css/form.css">
{{/partial}}

{{#partial "contenido"}}
    <section class="contenedor-form">
        <div class="panel">
            <div class="contenedor-titulo-volver">

                <div class="contenedor-titulo izq">
                    <a class="enlace" href="/">
                        <button class="boton secundario volver">
                            volver
                        </button>
                    </a>
                </div>

                <h2>Crear Solicitud de Eliminación</h2>

                <div class="contenedor-titulo der">
                    <button class="boton-secundario relleno">volver</button>
                </div>
            </div>
            <form class="form" style="height: 50%">

                <label>Titulo</label>
                <p class="bold"> {{hecho}} </p>

                <label>Fundamentacion</label>
                <input type="text" class="largo" placeholder="Motivos de eliminación"/>

                <button class="boton secundario" type="button">Subir</button>

            </form>
        </div>
    </section>
{{/partial}}

{{> templates/layout}}