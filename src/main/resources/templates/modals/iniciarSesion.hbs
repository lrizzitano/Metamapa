<div class ="modal" id="signinModal">
    <div class="backdrop" onclick="closeModal('signinModal')"></div>
    <div class="panel sign-in">
        <h2>Iniciar Sesión</h2>

        <form class="form-sign-in" id="signin" method="POST" action="/login">

            <label class="usuario-label" for="usuario">Usuario</label>
            <input type="text" class="usuario-input" name="nombreDeUsuario" id="usuario" placeholder="PabloTheKernelGOAT">

            <label for="password">Contraseña</label>
            <input type="password" name="password" id="password" placeholder="vedia1234">
            <div class="botones-form">
                <a href="/usuarios/nuevo">
                    <button class="boton secundario"
                            type="button">Registrarse</button>
                </a>
                <button class="boton principal" type="submit">Login</button>
            </div>
        </form>
    </div>
</div>